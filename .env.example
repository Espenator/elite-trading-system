# =========== Embodier Trader — Root .env ===========
# This file is for docker-compose and root-level scripts.
# For backend config, see backend/.env.example (copy to backend/.env).
# Only the settings below are needed at root level.

# =========== ALPACA (LIVE TRADING) ===========
ALPACA_API_KEY=your-alpaca-live-api-key
ALPACA_SECRET_KEY=your-alpaca-live-secret-key
ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
# sip = real-time consolidated feed (required for production)
ALPACA_FEED=sip
TRADING_MODE=paper
AUTO_EXECUTE_TRADES=false

# =========== FINVIZ ===========
FINVIZ_API_KEY=your-finviz-api-key
FINVIZ_BASE_URL=https://elite.finviz.com

# =========== FRED (Federal Reserve Economic Data) ===========
FRED_API_KEY=your-fred-api-key

# =========== UNUSUAL WHALES (Options Flow) ===========
UNUSUAL_WHALES_API_KEY=your-unusual-whales-api-key
UNUSUALWHALES_API_KEY=your-unusual-whales-api-key
UNUSUAL_WHALES_BASE_URL=https://api.unusualwhales.com/api

# =========== NEWS API (newsapi.org) ===========
NEWS_API_KEY=your-news-api-key

# =========== STOCKGEIST (Social Sentiment) ===========
STOCKGEIST_API_KEY=your-stockgeist-api-key

# =========== DISCORD ===========
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_IDS=channel-id-1,channel-id-2

# =========== X / TWITTER API ===========
X_API_KEY=your-x-api-key
X_API_KEY_SECRET=your-x-api-key-secret
X_OAUTH2_CLIENT_ID=your-x-oauth2-client-id
X_OAUTH2_CLIENT_SECRET=your-x-oauth2-client-secret

# =========== YOUTUBE ===========
YOUTUBE_API_KEY=your-youtube-api-key

# =========== RESEND (Email Alerts) ===========
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=alerts@yourdomain.com
RESEND_ALERT_TO_EMAIL=you@yourdomain.com

# =========== PERPLEXITY AI (Cloud LLM) ===========
PERPLEXITY_API_KEY=your-perplexity-api-key

# =========== ANTHROPIC (Claude LLM) ===========
ANTHROPIC_API_KEY=your-anthropic-api-key

# =========== OPENCLAW BRIDGE AUTHENTICATION ===========
OPENCLAW_ENABLED=true
OPENCLAW_BRIDGE_TOKEN=your-secure-shared-secret-here
GIST_TOKEN=your-github-pat-with-gist-scope
BRIDGE_GIST_ID=your-github-gist-id

# =========== DATABASE ===========
DATABASE_URL=duckdb:///data/elite_trading.duckdb

# =========== GPU / ML TRAINING ===========
GPU_DEVICE=auto
TORCH_MIXED_PRECISION=true
MODEL_ARTIFACTS_PATH=models/artifacts

# =========== API AUTHENTICATION (REQUIRED for live) ===========
# Shared token for API auth between frontend/PCs and backend.
# All state-changing endpoints (POST/PUT/DELETE) require this in live mode.
# Generate a token: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_AUTH_TOKEN=

# =========== SERVER ===========
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production

# =========== COUNCIL & TRIAGE ===========
COUNCIL_GATE_THRESHOLD=65
COUNCIL_GATE_ENABLED=true
COUNCIL_MAX_CONCURRENT=3
COUNCIL_COOLDOWN_SECS=120
# Triage: base priority threshold (0-100), min/max adaptive
TRIAGE_BASE_THRESHOLD=40
TRIAGE_MIN_THRESHOLD=20
TRIAGE_MAX_THRESHOLD=80

# =========== FIREHOSE ===========
FIREHOSE_ENABLED=true

# =========== AWARENESS WORKER (PC2 RTX/CUDA) ===========
# PC1 calls this URL for batch enrichment; must fail gracefully if PC2 down
AWARENESS_WORKER_URL=http://192.168.1.116:8000

# =========== TWO-PC NETWORK (LAN) ===========
# ESPENMAIN (PC1 - Primary) and ProfitTrader (PC2 - Secondary)
# Both IPs are DHCP-reserved (fixed allocation) on AT&T BGW320-505 router
# Router admin: http://192.168.1.254
#
# Machine 1 (ESPENMAIN) - Primary development, backend API host
PC1_HOSTNAME=ESPENMAIN
PC1_IP=192.168.1.105
PC1_MAC=CC:96:E5:38:F9:79
PC1_ROLE=primary
#
# Machine 2 (ProfitTrader) - GPU training, secondary services
PC2_HOSTNAME=ProfitTrader
PC2_IP=192.168.1.116
PC2_MAC=CC:96:E5:3B:58:4E
PC2_ROLE=secondary
#
# Cross-PC API access (use these instead of localhost when accessing from the other PC)
# From ProfitTrader, access ESPENMAIN backend:
PC1_API_URL=http://192.168.1.105:8000
PC1_WS_URL=ws://192.168.1.105:8000/ws
# From ESPENMAIN, access ProfitTrader services:
PC2_API_URL=http://192.168.1.116:8000
PC2_WS_URL=ws://192.168.1.116:8000/ws
#
# Frontend env override (set on ProfitTrader to point to ESPENMAIN backend)
# VITE_API_URL=http://192.168.1.105:8000
# VITE_WS_URL=ws://192.168.1.105:8000/ws
#
# LAN subnet: 192.168.1.0/24
# Gateway: 192.168.1.254
# No port forwarding needed (same LAN)
# No AP/LAN isolation enabled
