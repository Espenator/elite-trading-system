# ========== Elite Trading System .env Configuration ==========
# Copy this to .env and fill in your values

# ========== ALPACA (Paper Trading) ==========
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ========== OPENCLAW BRIDGE AUTHENTICATION ==========
# Shared secret token for OpenClaw bridge (must match OpenClaw side)
OPENCLAW_BRIDGE_TOKEN=your-secure-shared-secret-here

# ========== DATABASE ==========
DATABASE_URL=sqlite:///data/trading_orders.db

# ========== GPU / ML TRAINING ==========
GPU_DEVICE=cuda:0
TORCH_MIXED_PRECISION=true
MODEL_ARTIFACTS_PATH=models/artifacts

# ========== SERVER ==========
HOST=0.0.0.0
PORT=8001
