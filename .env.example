# =========== Elite Trading System .env Configuration ===========
# Copy this to .env and fill in your values
# All API keys default to empty -- features are disabled until configured.

# =========== ALPACA (Paper Trading) ===========
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
TRADING_MODE=paper

# =========== FINVIZ ===========
FINVIZ_API_KEY=your-finviz-api-key
FINVIZ_BASE_URL=https://elite.finviz.com

# =========== FRED (Federal Reserve Economic Data) ===========
FRED_API_KEY=your-fred-api-key

# =========== UNUSUAL WHALES (Options Flow) ===========
UNUSUAL_WHALES_API_KEY=your-unusual-whales-api-key
UNUSUAL_WHALES_BASE_URL=https://api.unusualwhales.com

# =========== NEWS API (newsapi.org) ===========
NEWS_API_KEY=your-news-api-key

# =========== STOCKGEIST (Social Sentiment) ===========
STOCKGEIST_API_KEY=your-stockgeist-api-key
STOCKGEIST_BASE_URL=https://api.stockgeist.ai

# =========== DISCORD ===========
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_IDS=channel-id-1,channel-id-2

# =========== X / TWITTER API ===========
X_API_KEY=your-x-api-key
X_API_KEY_SECRET=your-x-api-key-secret
X_OAUTH2_CLIENT_ID=your-x-oauth2-client-id
X_OAUTH2_CLIENT_SECRET=your-x-oauth2-client-secret

# =========== YOUTUBE ===========
YOUTUBE_API_KEY=your-youtube-api-key

# =========== RESEND (Email Alerts) ===========
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=alerts@yourdomain.com
RESEND_ALERT_TO_EMAIL=you@yourdomain.com

# =========== OPENCLAW BRIDGE AUTHENTICATION ===========
# Shared secret token for OpenClaw bridge (must match OpenClaw side)
OPENCLAW_BRIDGE_TOKEN=your-secure-shared-secret-here
OPENCLAW_BRIDGE_SECRET=your-hmac-secret-here
OPENCLAW_API_URL=http://192.168.x.x:5000

# =========== OPENCLAW GIST (GitHub Gist Bridge) ===========
OPENCLAW_GIST_ID=your-github-gist-id
OPENCLAW_GIST_TOKEN=your-github-pat-with-gist-scope

# =========== DATABASE ===========
DUCKDB_PATH=elite_trading.duckdb

# =========== GPU / ML TRAINING ===========
GPU_DEVICE=auto
TORCH_MIXED_PRECISION=true
MODEL_ARTIFACTS_PATH=models/artifacts

# =========== SERVER ===========
HOST=0.0.0.0
PORT=8000
