# Elite Trading System — Frontend .env.example (PRODUCTION)
# Copy to .env and fill in. Only VITE_* variables are exposed to the browser.

# ── API Connection ───────────────────────────────────────
# In dev mode, leave empty so Vite proxy forwards /api -> localhost:8000
# Set these when deploying to production (e.g. https://api.example.com)
VITE_API_URL=
VITE_WS_URL=

# ── API Authentication (REQUIRED for live trading) ───────
# Must match backend API_AUTH_TOKEN
VITE_API_AUTH_TOKEN=

# ── External API Keys ───────────────────────────────────
# https://financialmodelingprep.com/
VITE_FMP_API_KEY=your-fmp-api-key-here
