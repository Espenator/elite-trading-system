# Elite Trading System — Frontend .env.example
# Copy to .env and fill in. Only VITE_* variables are exposed to the browser.

# ── API Connection ───────────────────────────────────────
# Backend API URL (required for production; defaults to localhost:8000 in dev)
VITE_API_URL=http://localhost:8000
# WebSocket URL (auto-derived from API_URL if not set)
VITE_WS_URL=ws://localhost:8000/ws

# ── API Authentication ───────────────────────────────────
# Must match backend API_AUTH_TOKEN
# Leave empty to skip auth (paper/dev mode only)
VITE_API_AUTH_TOKEN=

# ── External API Keys ───────────────────────────────────
# https://financialmodelingprep.com/
VITE_FMP_API_KEY=your-fmp-api-key-here

# ── Feature Flags ────────────────────────────────────────
# Set to "true" to enable mock agent responses (dev only)
# VITE_ENABLE_AGENT_MOCKS=false
