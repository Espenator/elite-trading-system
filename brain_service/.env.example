# Brain Service (PC2) — gRPC + Ollama LLM Inference
# Run on the GPU machine alongside Ollama

# gRPC server port (PC1 connects to this)
GRPC_PORT=50051

# Ollama settings (must be running: ollama serve)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M
OLLAMA_FLASH_ATTENTION=1
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_CTX=4096
OLLAMA_KEEP_ALIVE=10m
CUDA_VISIBLE_DEVICES=0

# Brain worker pool (RTX 4080 recommendation)
BRAIN_MAX_WORKERS=12

# Logging
LOG_LEVEL=INFO
