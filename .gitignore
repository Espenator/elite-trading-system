.embodier.pid
backend/.embodier.pid

# ── Environment (AUDIT FIX Task 16: catch ALL .env variants) ──
.env*
!.env.example
!.env.pc1
!.env.pc2
.github-token
backend/.env*
!backend/.env.example
APIFINAL*.env
APIFINAL*.xlsx
*-backend.env
*-frontend*.env
*-COMPLETE.env

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
*.egg-info/
dist/
build/

# ── Database files ──
*.db
*.sqlite
*.sqlite3
finviz_stocks.db
*.duckdb
*.duckdb.wal

