# Elite Trading System - Git Ignore

# ============================================================================
# SENSITIVE DATA - NEVER COMMIT THESE!
# ============================================================================
.env
credentials/*.json
*.key
*.pem

# ============================================================================
# CACHED DATA
# ============================================================================
data/cache/**
data/logs/**
data/exports/**
*.csv
*.pkl
*.parquet

# ============================================================================
# ML MODELS
# ============================================================================
data/models/*.pkl
data/models/*.h5
data/models/*.onnx

# ============================================================================
# PYTHON
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============================================================================
# VIRTUAL ENVIRONMENTS
# ============================================================================
venv/
env/
ENV/
.venv

# ============================================================================
# IDE
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# JUPYTER NOTEBOOKS
# ============================================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================================
# TESTING
# ============================================================================
.pytest_cache/
.coverage
htmlcov/

# ============================================================================
# SYSTEM FILES
# ============================================================================
Thumbs.db
desktop.ini

# ============================================================================
# KEEP THESE FOLDERS (but not contents)
# ============================================================================
!data/cache/.gitkeep
!data/logs/.gitkeep
!data/models/.gitkeep
!data/exports/.gitkeep
!credentials/.gitkeep
