# =========== Embodier Trader — PC1 (ESPENMAIN) .env ===========
# Copy to backend/.env on PC1. Never commit secrets.
# PC1 = PRIMARY: FastAPI, council DAG, DuckDB, scheduler, WebSocket, frontend

# ── Machine Identity ─────────────────────────────────────
PC_ROLE=primary
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ── Backend Server ───────────────────────────────────────
HOST=0.0.0.0
PORT=8000
TRADING_MODE=paper

# ── Brain Service (PC2 gRPC) ────────────────────────────
# PC1 connects to PC2's brain_service for LLM inference
BRAIN_ENABLED=true
BRAIN_HOST=192.168.1.116
BRAIN_PORT=50051
BRAIN_SERVICE_URL=192.168.1.116:50051
BRAIN_SERVICE_TIMEOUT=1.5
BRAIN_CONNECT_TIMEOUT=5
BRAIN_REQUEST_TIMEOUT=15

# ── LLM Intelligence ────────────────────────────────────
LLM_ENABLED=true
LLM_PREFER_LOCAL=true
LLM_ROUTER_ENABLED=true
LLM_COST_TRACKING=true
LLM_DISPATCHER_ENABLED=true
LLM_DISPATCHER_HEARTBEAT_TIMEOUT=3
LLM_DISPATCHER_FALLBACK_MODEL=mistral:7b
LLM_DISPATCHER_GPU_UTIL_THRESHOLD=85.0

# PC1 fallback Ollama (lightweight models only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_URL=
OLLAMA_MODEL=mistral:7b
LOCAL_LLM_MODEL=qwen2.5:14b

# Model pinning
MODEL_PIN_PC1=mistral:7b
MODEL_PIN_PC2=gemma3:12b,qwen3:8b
MODEL_PIN_TASK_AFFINITY=regime_classification:pc1,signal_scoring:pc1,risk_check:pc1,quick_hypothesis:pc1,feature_summary:pc1,trade_thesis:pc2,strategy_critic:pc2,deep_postmortem:pc2,strategy_evolution:pc2,overnight_analysis:pc2

# ── Perplexity (LLM Tier 2) ─────────────────────────────
PERPLEXITY_API_KEY=<your-perplexity-api-key>
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_ENABLED=true

# ── Anthropic / Claude (LLM Tier 3 — deep reasoning only)
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Redis (Cross-PC MessageBus Bridge) ──────────────────
REDIS_URL=redis://192.168.1.105:6379
REDIS_REQUIRED=false

# ── Cluster / Multi-PC ──────────────────────────────────
CLUSTER_PC2_HOST=192.168.1.116
CLUSTER_HEALTH_INTERVAL=60
OLLAMA_PC2_URL=http://192.168.1.116:11434
SCANNER_OLLAMA_URLS=http://localhost:11434,http://192.168.1.116:11434

# ── Alpaca Markets (Paper Trading) ──────────────────────
ALPACA_API_KEY=<your-alpaca-api-key-1>
ALPACA_SECRET_KEY=<your-alpaca-secret-key-1>
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_FEED=iex
APCA_API_KEY_ID=<your-alpaca-api-key-1>
APCA_API_SECRET_KEY=<your-alpaca-secret-key-1>
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Multi-Key (Key 2 = PC2 discovery)
ALPACA_KEY_2=<your-alpaca-key-2>
ALPACA_SECRET_2=<your-alpaca-secret-2>

# ── DuckDB ──────────────────────────────────────────────
DUCKDB_PATH=./data/trading.duckdb
DATABASE_URL=duckdb:///data/elite_trading.duckdb

# ── Data Sources ────────────────────────────────────────
FINVIZ_API_KEY=<your-finviz-api-key>
FRED_API_KEY=<your-fred-api-key>
NEWS_API_KEY=<your-news-api-key>
UNUSUAL_WHALES_API_KEY=<your-unusual-whales-api-key>
UNUSUALWHALES_API_KEY=<your-unusual-whales-api-key>
SEC_EDGAR_USER_AGENT=EspenSchiefloe espen@embodier.ai
BENZINGA_EMAIL=<your-benzinga-email>
BENZINGA_PASSWORD=<your-benzinga-password>
SQUEEZEMETRICS_ENABLED=true

# ── Council ─────────────────────────────────────────────
COUNCIL_ENABLED=true
COUNCIL_GATE_ENABLED=true

# ── Execution & Risk ────────────────────────────────────
KELLY_MAX_ALLOCATION=0.10
MAX_PORTFOLIO_HEAT=0.06
MAX_SINGLE_POSITION=0.02
MAX_DAILY_TRADES=10
AUTO_EXECUTE_TRADES=false
AUTO_EXECUTE_ENABLED=true
SLIPPAGE_BPS=5.0
PARTIAL_FILL_ENABLED=true

# ── Scheduler ───────────────────────────────────────────
SCHEDULER_ENABLED=true

# ── WebSocket ───────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100

# ── GPU Telemetry ───────────────────────────────────────
GPU_TELEMETRY_ENABLED=true
GPU_TELEMETRY_INTERVAL=3.0
GPU_VRAM_HEADROOM_MB=512

# ── Auth (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
API_AUTH_TOKEN=<your-api-auth-token>
FERNET_KEY=<your-fernet-key>

# ── Notifications ───────────────────────────────────────
SLACK_BOT_TOKEN=<your-slack-bot-token>
SLACK_ENABLED=false
RESEND_API_KEY=<your-resend-api-key>
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>

# ── TradingView / TradersPost ───────────────────────────
TRADINGVIEW_WEBHOOK_URL=<your-webhook-site-url>
TRADERSPOST_WEBHOOK_URL=<your-traderspost-webhook-url>

# ── Streaming ───────────────────────────────────────────
STREAMING_ENABLED=true
STREAMING_BAR_TIMEFRAME=1Min
