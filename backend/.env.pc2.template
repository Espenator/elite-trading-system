# =============================================================================
# Embodier Trader -- PC2 (ProfitTrader) Environment Configuration
# Role: Execution Plane -- GPU inference, trading engine, council DAG, DuckDB
# Hardware: i7-13700 (8P+8E) | RTX 4080 16GB | 32GB RAM
# =============================================================================

# --- Machine Identity ---
PC_ROLE=secondary
HOST=0.0.0.0
PORT=8001
ENVIRONMENT=production

# --- Peer (PC1 ESPENMAIN) ---
CLUSTER_PC2_HOST=
PC2_HOST=localhost

# --- Redis (cross-PC event bus, hosted on PC1) ---
REDIS_URL=redis://192.168.1.105:6379/0
REDIS_HOST=192.168.1.105

# --- Brain Service (local on PC2) ---
BRAIN_HOST=localhost
BRAIN_PORT=50051
BRAIN_ENABLED=true
BRAIN_MAX_WORKERS=8
BRAIN_OLLAMA_MODEL=gemma3:12b

# --- LLM / Ollama (local GPU) ---
LLM_ENABLED=true
LLM_ROUTER_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b
OLLAMA_SMALL_MODEL=qwen3:8b
OLLAMA_LARGE_MODEL=gemma3:12b
OLLAMA_PRIMARY_MODEL=gemma3:12b
OLLAMA_SECONDARY_MODEL=qwen3:8b
MODEL_PIN_PC2=gemma3:12b,qwen3:8b
LLM_DISPATCHER_GPU_UTIL_THRESHOLD=85.0

# --- GPU / CUDA ---
GPU_TELEMETRY_ENABLED=true
CUDA_VISIBLE_DEVICES=0

# --- Services (PC2 runs the heavy execution path) ---
TURBO_SCANNER_ENABLED=false
STARTUP_BACKFILL_ENABLED=false
DATA_SWARM_ENABLED=false
AUTO_BACKFILL=false
DISABLE_ALPACA_DATA_STREAM=true

# --- Alpaca (Key 2 -- discovery scanning) ---
# ALPACA_API_KEY=<your-key-2>
# ALPACA_SECRET_KEY=<your-secret-2>
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Thread Pool (larger for GPU/DuckDB offloading) ---
ASYNCIO_THREAD_POOL_WORKERS=64
