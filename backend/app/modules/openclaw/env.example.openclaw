# ========== OpenClaw .env Configuration ==========
# Copy this to .env and fill in your API keys

# ========== SLACK ==========
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# ========== ALPACA (Paper Trading) ==========
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ========== FINVIZ ELITE ==========
# Get your token from: https://elite.finviz.com/export.ashx
# Step 4: "Add Authentication" -> copy your API token
FINVIZ_API_KEY=your-finviz-elite-api-token

# ========== UNUSUAL WHALES ==========
UNUSUALWHALES_API_KEY=your-unusual-whales-api-key

# ========== DISCORD LISTENER ==========
# Get from browser DevTools > Network > Authorization header
DISCORD_USER_TOKEN=your-discord-user-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ========== TRADINGVIEW ==========
# Optional: webhook URL for auto-updating TV watchlist
TRADINGVIEW_WEBHOOK_SECRET=
TRADINGVIEW_WEBHOOK_URL=

# ========== GOOGLE SHEETS ==========
GOOGLE_SHEETS_CREDENTIALS=credentials.json
TRADE_LOG_SHEET_ID=your-google-sheet-id

# ========== BOT SETTINGS ==========
TRADE_CONFIRM_TIMEOUT=300
MAX_DAILY_LOSS_PCT=2.0
DEFAULT_RISK_PCT=1.5

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_TO_FILE=True
LOG_FILE_PATH=openclaw.log

# ========== FRED (Federal Reserve Economic Data) ==========
# Get free API key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# ========== STOCKGEIST SENTIMENT ==========
# Get your API token from: https://dashboard.stockgeist.ai
# REST API docs: https://api.stockgeist.ai/v2/docs
# Free tier: 10k credits/month + 5 SSE streams
STOCKGEIST_API_URL=https://api.stockgeist.ai
STOCKGEIST_TOKEN=your-stockgeist-api-token
# Legacy auth (deprecated - use STOCKGEIST_TOKEN instead)
# STOCKGEIST_AUTH=your-email@example.com:your-password

# ========== NEWS API ==========
# Get free API key at: https://newsapi.org
NEWS_API_KEY=your-newsapi-key

# ========== YOUTUBE DATA API v3 ==========
# Get from Google Cloud Console: https://console.cloud.google.com
YOUTUBE_API_KEY=your-youtube-api-key

# ========== X / TWITTER (Full OAuth) ==========
# Get from https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=your-x-bearer-token
X_API_KEY=your-x-api-key
X_API_KEY_SECRET=your-x-api-key-secret
X_OAUTH_ACCESS_SECRET=your-x-oauth-access-secret
X_OAUTH2_CLIENT_ID=your-x-oauth2-client-id

# ========== SEC EDGAR (Free Government API - No Key Required) ==========
# Base URL: https://data.sec.gov
# Only requires a User-Agent header with company name + email
# See: https://www.sec.gov/search#/dateRange=custom&startdt=2024-01-01
SEC_EDGAR_BASE_URL=https://data.sec.gov
SEC_EDGAR_USER_AGENT=Embodier.ai espen@embodier.ai

# ========== SLACK CHANNELS ==========
OC_TRADE_DESK_CHANNEL=C0AF9RW7W94
OC_SIGNALS_RAW_CHANNEL=C0AFQR1GUSV

# ========== AI BRIDGE (Perplexity Tasks Integration) ==========
# Create a GitHub Gist (public) and note the Gist ID
# Generate a GitHub PAT with 'gist' scope at: https://github.com/settings/tokens
# NOTE: In GitHub Actions, the repo secret is named GH_GIST_TOKEN (GITHUB_ prefix not allowed), mapped to env var GIST_TOKEN
GIST_TOKEN=your-github-pat-with-gist-scope
BRIDGE_GIST_ID=your-gist-id-created-once
AI_BRIDGE_ENABLED=True

# ========== ELITE TRADING SYSTEM BRIDGE (PC2 Connection) ==========
# Set to the LAN IP of PC2 running the Elite Trading System
ELITE_API_URL=http://192.168.1.XXX:8001
# Shared secret token for bridge authentication (must match Elite side)
OPENCLAW_BRIDGE_TOKEN=your-secure-shared-secret-here
ELITE_ENABLED=true
REDIS_URL=redis://localhost:6379
