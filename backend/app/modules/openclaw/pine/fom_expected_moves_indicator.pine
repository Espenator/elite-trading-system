// FOM Expected Move Levels - OpenClaw Automated Edition
// 
// Draws daily expected move levels (1σ and 2σ) as horizontal lines.
// Data source: OpenClaw api_data_bridge.py → GitHub Gist → Slack → paste here
// 
// USAGE:
//   1. OpenClaw 7 AM scan scrapes FOM #daily-expected-moves from Discord
//   2. Formatted string posted to Slack #oc-trade-desk
//   3. Copy the block from Slack and paste into "Paste DEM Levels" input below
//   4. Format: TICKER,1sigUp,1sigDn,2sigUp,2sigDn;
//      Example: SPY,688.38,677.32,693.91,671.79;
//
// The indicator auto-matches the current chart symbol.

//@version=5
indicator("FOM Expected Move Levels [OpenClaw]", overlay=true, max_lines_count=4, max_labels_count=4)

// ── Inputs ──────────────────────────────────────────────────────────────
i_demLevels = input.text_area(defval="SPY,688.38,677.32,693.91,671.79;\nQQQ,510.15,501.85,514.30,497.70;\nIWM,225.40,220.60,227.80,218.20;", title="Paste DEM Levels", tooltip="Paste the FOM DEM string from Slack #oc-trade-desk.\nFormat: TICKER,1σUp,1σDn,2σUp,2σDn;\nOne ticker per line.")

i_show1sig = input.bool(defval=true, title="Show 1σ Levels", group="Display")
i_show2sig = input.bool(defval=true, title="Show 2σ Levels", group="Display")
i_extend   = input.string(defval="right", title="Extend Lines", options=["none", "left", "right", "both"], group="Display")
i_lineWidth = input.int(defval=2, title="Line Width", minval=1, maxval=4, group="Display")

i_col1sigUp = input.color(defval=color.new(color.green, 20), title="1σ Upper", group="Colors")
i_col1sigDn = input.color(defval=color.new(color.red, 20), title="1σ Lower", group="Colors")
i_col2sigUp = input.color(defval=color.new(color.green, 60), title="2σ Upper", group="Colors")
i_col2sigDn = input.color(defval=color.new(color.red, 60), title="2σ Lower", group="Colors")
i_fillAlpha = input.int(defval=90, title="Fill Transparency", minval=0, maxval=100, group="Colors")

// ── Symbol matching ─────────────────────────────────────────────────────
chartSym = syminfo.ticker

// ── Parse the input text to find matching ticker ────────────────────────
// Pine Script string parsing: split by semicolons, then by commas
parseLevels(inputStr, sym) =>
    float u1 = na
    float d1 = na
    float u2 = na
    float d2 = na
    bool found = false
    
    // Try to find the ticker in the input string
    // Look for pattern: SYM,num,num,num,num;
    searchStr = sym + ","
    pos = str.pos(inputStr, searchStr)
    
    if not na(pos)
        // Found the ticker - extract the rest of the line until ;
        afterTicker = str.substring(inputStr, pos + str.length(searchStr))
        semiPos = str.pos(afterTicker, ";")
        if not na(semiPos)
            numStr = str.substring(afterTicker, 0, semiPos)
            // Split by commas to get the 4 values
            c1 = str.pos(numStr, ",")
            if not na(c1)
                v1str = str.substring(numStr, 0, c1)
                rest1 = str.substring(numStr, c1 + 1)
                c2 = str.pos(rest1, ",")
                if not na(c2)
                    v2str = str.substring(rest1, 0, c2)
                    rest2 = str.substring(rest1, c2 + 1)
                    c3 = str.pos(rest2, ",")
                    if not na(c3)
                        v3str = str.substring(rest2, 0, c3)
                        v4str = str.substring(rest2, c3 + 1)
                        u1 := str.tonumber(v1str)
                        d1 := str.tonumber(v2str)
                        u2 := str.tonumber(v3str)
                        d2 := str.tonumber(v4str)
                        found := true
    [u1, d1, u2, d2, found]

[upper1, lower1, upper2, lower2, matched] = parseLevels(i_demLevels, chartSym)

// ── Extension mode ──────────────────────────────────────────────────────
extendMode = switch i_extend
    "none"  => extend.none
    "left"  => extend.left
    "right" => extend.right
    "both"  => extend.both

// ── Draw lines on last bar only ─────────────────────────────────────────
var line l_1sigUp = na
var line l_1sigDn = na
var line l_2sigUp = na
var line l_2sigDn = na
var label lb_1sigUp = na
var label lb_1sigDn = na
var label lb_2sigUp = na
var label lb_2sigDn = na

if barstate.islast and matched
    // Clean up previous drawings
    line.delete(l_1sigUp)
    line.delete(l_1sigDn)
    line.delete(l_2sigUp)
    line.delete(l_2sigDn)
    label.delete(lb_1sigUp)
    label.delete(lb_1sigDn)
    label.delete(lb_2sigUp)
    label.delete(lb_2sigDn)
    
    if i_show1sig
        l_1sigUp := line.new(bar_index - 1, upper1, bar_index, upper1, color=i_col1sigUp, width=i_lineWidth, extend=extendMode, style=line.style_solid)
        l_1sigDn := line.new(bar_index - 1, lower1, bar_index, lower1, color=i_col1sigDn, width=i_lineWidth, extend=extendMode, style=line.style_solid)
        lb_1sigUp := label.new(bar_index + 5, upper1, "1σ Up " + str.tostring(upper1, "#.##"), style=label.style_none, textcolor=i_col1sigUp, size=size.small)
        lb_1sigDn := label.new(bar_index + 5, lower1, "1σ Dn " + str.tostring(lower1, "#.##"), style=label.style_none, textcolor=i_col1sigDn, size=size.small)
    
    if i_show2sig
        l_2sigUp := line.new(bar_index - 1, upper2, bar_index, upper2, color=i_col2sigUp, width=i_lineWidth, extend=extendMode, style=line.style_dashed)
        l_2sigDn := line.new(bar_index - 1, lower2, bar_index, lower2, color=i_col2sigDn, width=i_lineWidth, extend=extendMode, style=line.style_dashed)
        lb_2sigUp := label.new(bar_index + 5, upper2, "2σ Up " + str.tostring(upper2, "#.##"), style=label.style_none, textcolor=i_col2sigUp, size=size.small)
        lb_2sigDn := label.new(bar_index + 5, lower2, "2σ Dn " + str.tostring(lower2, "#.##"), style=label.style_none, textcolor=i_col2sigDn, size=size.small)

// ── Fill between 1σ bands ───────────────────────────────────────────────
// Use plot-based fill for the 1σ range
p_u1 = plot(matched and i_show1sig ? upper1 : na, color=color.new(color.green, 100), display=display.none)
p_d1 = plot(matched and i_show1sig ? lower1 : na, color=color.new(color.red, 100), display=display.none)
fill(p_u1, p_d1, color=color.new(color.gray, i_fillAlpha), title="1σ Fill")

// ── Table: show status ──────────────────────────────────────────────────
var table statusTbl = table.new(position.top_right, 2, 3, bgcolor=color.new(color.black, 80))

if barstate.islast
    if matched
        table.cell(statusTbl, 0, 0, "FOM DEM", text_color=color.white, text_size=size.small)
        table.cell(statusTbl, 1, 0, chartSym, text_color=color.lime, text_size=size.small)
        table.cell(statusTbl, 0, 1, "1σ Range", text_color=color.gray, text_size=size.tiny)
        table.cell(statusTbl, 1, 1, str.tostring(lower1, "#.##") + " → " + str.tostring(upper1, "#.##"), text_color=color.white, text_size=size.tiny)
        table.cell(statusTbl, 0, 2, "2σ Range", text_color=color.gray, text_size=size.tiny)
        table.cell(statusTbl, 1, 2, str.tostring(lower2, "#.##") + " → " + str.tostring(upper2, "#.##"), text_color=color.white, text_size=size.tiny)
    else
        table.cell(statusTbl, 0, 0, "FOM DEM", text_color=color.white, text_size=size.small)
        table.cell(statusTbl, 1, 0, "No data for " + chartSym, text_color=color.orange, text_size=size.small)
