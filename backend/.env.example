# Elite Trading System - Backend Environment Configuration
# Copy this to .env and customize as needed

# Application
APP_NAME=Elite Trading System API
DEBUG=False

# Database (SQLite by default)
DATABASE_URL=sqlite:///./finviz_stocks.db

# Finviz Scraper Settings
FINVIZ_USE_ELITE=False
DEFAULT_FILTERS=cap_midover,sh_avgvol_o500,sh_price_o10

# Optional: Use PostgreSQL for production
# DATABASE_URL=postgresql://user:password@localhost:5432/elite_trading
