# Embodier Trader — Backend Environment Configuration
# Copy to backend/.env and fill in your credentials
# Never commit .env to version control

# ── App Settings ─────────────────────────────────────────
APP_NAME=Embodier Trader API
APP_VERSION=4.1.0
DEBUG=False
LOG_LEVEL=INFO
ENVIRONMENT=production
# Backend listen port. Must match frontend defaults (api.js, vite.config.js = 8000).
PORT=8000
HOST=0.0.0.0
TRADING_MODE=paper
SCAN_INTERVAL_MINUTES=5

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8501,http://localhost:3002

# ── WebSocket ────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100

# ── Alpaca Markets (LIVE TRADING) ────────────────────────
# https://alpaca.markets/
ALPACA_API_KEY=your-alpaca-live-api-key
ALPACA_SECRET_KEY=your-alpaca-live-secret-key
ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
# sip = real-time consolidated feed (required for production)
ALPACA_FEED=sip
# Duplicate env names used by alpaca-py SDK
APCA_API_KEY_ID=your-alpaca-live-api-key
APCA_API_SECRET_KEY=your-alpaca-live-secret-key
APCA_API_BASE_URL=https://api.alpaca.markets

# Multi-Key Alpaca (optional — leave empty for single-key mode)
# Each key gets its own WebSocket connection (Alpaca allows 1 per account)
# Key 1: Trading (portfolio symbols), Key 2: Discovery A, Key 3: Discovery B
ALPACA_KEY_1=
ALPACA_SECRET_1=
ALPACA_KEY_2=
ALPACA_SECRET_2=
ALPACA_KEY_3=
ALPACA_SECRET_3=

# ── Finviz Elite ─────────────────────────────────────────
# https://elite.finviz.com/
FINVIZ_API_KEY=your-finviz-api-key
FINVIZ_BASE_URL=https://elite.finviz.com
FINVIZ_SCREENER_FILTERS=sh_avgvol_o500,sh_price_u500
FINVIZ_SCREENER_FILTER_TYPE=4
FINVIZ_SCREENER_VERSION=111
FINVIZ_QUOTE_TIMEFRAME=d

# ── FRED (Federal Reserve Economic Data) ─────────────────
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# ── SEC EDGAR ────────────────────────────────────────────
SEC_EDGAR_USER_AGENT=YourName your@email.com

# ── News API ─────────────────────────────────────────────
# https://newsapi.org/
NEWS_API_KEY=your-news-api-key

# ── StockGeist (Social Sentiment) ────────────────────────
# https://stockgeist.ai/
STOCKGEIST_API_KEY=your-stockgeist-api-key
STOCKGEIST_BASE_URL=https://api.stockgeist.ai

# ── Unusual Whales (Options Flow) ────────────────────────
# https://unusualwhales.com/
UNUSUAL_WHALES_API_KEY=your-unusual-whales-api-key
# OpenClaw uses this alternate name:
UNUSUALWHALES_API_KEY=your-unusual-whales-api-key
UNUSUAL_WHALES_BASE_URL=https://api.unusualwhales.com/api

# ── Benzinga (Earnings Calendar & Transcripts) ───────────
# https://www.benzinga.com/ — no API key, uses authenticated web scraping
BENZINGA_EMAIL=your-benzinga-email
BENZINGA_PASSWORD=your-benzinga-password

# ── SqueezeMetrics (DIX/GEX) ────────────────────────────
# https://squeezemetrics.com/ — free public data, scraped (no API)
SQUEEZEMETRICS_ENABLED=true

# ── YouTube Knowledge Agent ──────────────────────────────
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_SEARCH_QUERY=stock trading signals analysis

# ── X / Twitter ──────────────────────────────────────────
# https://developer.x.com/
X_API_KEY=your-x-api-key
X_API_KEY_SECRET=your-x-api-key-secret
X_OAUTH2_CLIENT_ID=your-x-oauth2-client-id
X_OAUTH2_CLIENT_SECRET=your-x-oauth2-client-secret
# OpenClaw read-only API v2 bearer token:
X_BEARER_TOKEN=

# ── Discord ──────────────────────────────────────────────
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_IDS=
DISCORD_UW_CHANNEL_ID=
DISCORD_UW_LIVE_CHANNEL_ID=
DISCORD_FOM_CHANNEL_ID=
DISCORD_FOM_ZONES_CHANNEL_ID=
DISCORD_FOM_IVOL_CHANNEL_ID=
DISCORD_EXPECTED_MOVES_CHANNEL_ID=
DISCORD_MAVERICK_CHANNEL_ID=

# ── Slack (Embodier Trader Workspace) ──────────────────
# Bot 1: OpenClaw (App ID: A0AF9HSCQ6S) — swarm notifications
# Bot 2: TradingView Alerts (App ID: A0AFQ89RVEV) — inbound webhooks
# Tokens expire every 12 hours — refresh at https://api.slack.com/apps
SLACK_APP_TOKEN=your-slack-app-token
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_CHANNEL_ALERTS=
SLACK_CHANNEL_TRADES=
SLACK_ENABLED=false

# ── Resend (Email Alerts) ───────────────────────────────
# https://resend.com/
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=alerts@yourdomain.com
RESEND_ALERT_TO_EMAIL=you@yourdomain.com

# ── Telegram (Alerts) ───────────────────────────────────
# https://core.telegram.org/bots
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Multi-LLM Intelligence Layer ────────────────────────
# https://docs.perplexity.ai/
PERPLEXITY_API_KEY=your-perplexity-api-key
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_ENABLED=true
# https://docs.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Local LLM via Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
LOCAL_LLM_MODEL=qwen3:14b
LLM_ENABLED=true
LLM_PREFER_LOCAL=true
LLM_ROUTER_ENABLED=true

# ── Brain Service (PC2 gRPC) — canonical LLM entrypoint ─
# PC1: set to PC2 IP:port so hypothesis_agent and critic_agent use gRPC (e.g. 192.168.1.116:50051)
BRAIN_SERVICE_URL=192.168.1.116:50051
BRAIN_ENABLED=true
BRAIN_HOST=localhost
BRAIN_PORT=50051
# OLLAMA_URL = PC1 fallback (empty = use OLLAMA_BASE_URL). PC1 runs llama3.2 + mistral:7b only.
OLLAMA_URL=

# ── PC Role ──────────────────────────────────────────
# "primary" (PC1 / single-PC) or "secondary" (PC2 / brain compute node)
PC_ROLE=primary

# ── Cluster / Multi-PC ────────────────────────────────
# PC1: set to PC2 IP (e.g. 192.168.1.116). PC2: leave empty or set to PC1 for discovery.
CLUSTER_PC2_HOST=192.168.1.116
CLUSTER_HEALTH_INTERVAL=60

# ── Redis (Cross-PC MessageBus Bridge) ────────────────
# PC1 (ESPENMAIN): Set to redis://localhost:6379 — required for dual-PC. PC2 connects to 192.168.1.105:6379.
# Enables real-time pub/sub between PC1 and PC2 for cluster topics.
# Leave empty for local-only MessageBus (single-PC). Set REDIS_REQUIRED=true to fail startup if Redis down.
REDIS_URL=redis://localhost:6379

# Ollama multi-node pool (comma-separated, optional)
# Example: http://localhost:11434,http://192.168.1.100:11434
SCANNER_OLLAMA_URLS=

# ── GPU Telemetry ─────────────────────────────────────
GPU_TELEMETRY_ENABLED=true
GPU_TELEMETRY_INTERVAL=3.0
GPU_VRAM_HEADROOM_MB=512

# ── Model Pinning (Asymmetric Routing) ────────────────
# PC1 = fast tactical models, PC2 = heavy deep-thinking models
MODEL_PIN_PC1=llama3.2,mistral:7b
MODEL_PIN_PC2=deepseek-r1:14b,mixtral:8x7b
# Task:node affinity pairs (overrides round-robin for specific tasks)
MODEL_PIN_TASK_AFFINITY=regime_classification:pc1,signal_scoring:pc1,risk_check:pc1,quick_hypothesis:pc1,feature_summary:pc1,trade_thesis:pc2,strategy_critic:pc2,deep_postmortem:pc2,strategy_evolution:pc2,overnight_analysis:pc2

# ── LLM Dispatcher ────────────────────────────────────
LLM_DISPATCHER_ENABLED=true
LLM_DISPATCHER_HEARTBEAT_TIMEOUT=3
LLM_DISPATCHER_FALLBACK_MODEL=llama3.2
LLM_DISPATCHER_GPU_UTIL_THRESHOLD=85.0

# ── Council (35-Agent DAG) ─────────────────────────────
# CouncilGate on PC1 evaluates every signal before order execution. hypothesis + critic use PC2 brain gRPC.
COUNCIL_ENABLED=true
COUNCIL_GATE_ENABLED=true

# ── OpenClaw (Multi-Agent Swarm) ────────────────────────
OPENCLAW_ENABLED=true
OPENCLAW_BRIDGE_TOKEN=your-bridge-token
GIST_TOKEN=your-github-pat-with-gist-scope
BRIDGE_GIST_ID=your-github-gist-id

# ── Kelly Criterion & Position Sizing ────────────────────
KELLY_MAX_ALLOCATION=0.10
KELLY_DEFAULT_WIN_RATE=0.55
KELLY_DEFAULT_AVG_WIN=0.035
KELLY_DEFAULT_AVG_LOSS=0.015
KELLY_USE_HALF=True

# ── Risk Management ─────────────────────────────────────
MAX_PORTFOLIO_HEAT=0.06
MAX_SINGLE_POSITION=0.02
MAX_SECTOR_CONCENTRATION=0.30
MAX_DAILY_LOSS_PCT=2.0
DEFAULT_RISK_PCT=1.5
MIN_RISK_SCORE=3.0
VOLATILITY_BASELINE=0.15
CIRCUIT_BREAKER_THRESHOLD=-0.03
ATR_STOP_MULTIPLIER=2.0
MAX_DAILY_DRAWDOWN_PCT=5.0
AUTO_PAUSE_TRADING=True
TRAILING_STOP_PCT=0.03
MAX_POSITION_PCT=0.10

# ── Signal Thresholds ───────────────────────────────────
SIGNAL_BUY_THRESHOLD=0.60
SIGNAL_STRONG_BUY_THRESHOLD=0.75
SIGNAL_MIN_EDGE=0.05
SIGNAL_MIN_VOLUME_SCORE=0.5

# ── Execution ────────────────────────────────────────────
SLIPPAGE_BPS=5.0
PARTIAL_FILL_ENABLED=true
AUTO_EXECUTE_TRADES=false
AUTO_EXECUTE_ENABLED=true
MAX_DAILY_TRADES=10

# ── Feature Toggles ────────────────────────────────────
TURBO_SCANNER_ENABLED=true
MARKET_SWEEP_ENABLED=true
SCOUTS_ENABLED=true
# STARTUP_BACKFILL_ENABLED=false
# DISABLE_ALPACA_DATA_STREAM=false
# AUTO_BACKFILL=false
# DATA_SWARM_ENABLED=true
# CHANNELS_FIREHOSE_ENABLED=false

# ── Scheduler ───────────────────────────────────────────
SCHEDULER_ENABLED=true

# ── Database ────────────────────────────────────────────
DATABASE_URL=duckdb:///data/elite_trading.duckdb

# ── Efficiency / performance (see docs/EFFICIENCY-AND-HARDWARE-DESIGN.md) ──
# PC1: uvicorn workers (default 4 to match P-cores). Set DEBUG=true for single-worker + reload.
# UVICORN_WORKERS=4
# ASYNCIO_THREAD_POOL_WORKERS=64
# FEATURE_AGGREGATOR_WORKERS=4
# BAR_BUFFER_FLUSH_SEC=5.0

# ── ML Engine ───────────────────────────────────────────
ML_MODEL_DIR=data/models
ML_RETRAIN_INTERVAL_HOURS=168
ML_ENSEMBLE_ENABLED=true

# ── Streaming ───────────────────────────────────────────
STREAMING_ENABLED=true
STREAMING_BAR_TIMEFRAME=1Min
SCORE_TRIGGER_THRESHOLD=75

# ── Stability & Debug ─────────────────────────────────────
# Disable scouts to isolate scout-related startup hangs
# SCOUTS_ENABLED=false
# Disable Alpaca WebSocket stream (fall back to REST snapshots)
# DISABLE_ALPACA_DATA_STREAM=1
# Delay (seconds) before Alpaca WS connects after startup — avoids
# "connection limit exceeded" when previous connection hasn't fully closed
ALPACA_WS_CONNECT_DELAY=30
# Override log file path (default: logs/backend.log, rotated at 10MB x3)
# LOG_FILE=/path/to/backend.log
# Delay (seconds) before heavy deferred services start
# DEFERRED_STARTUP_DELAY=15

# ── API Authentication (REST + WebSocket) ───────────────────
# Required for state-changing endpoints; when set, WebSocket /ws requires ?token=<this>
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_AUTH_TOKEN=

# ── Encryption Key ──────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for persistent credential encryption across restarts
FERNET_KEY=

# ── TradingView / TradersPost Integration ─────────────────
# Webhook.site URL for monitoring outbound signal payloads (always fires)
TRADINGVIEW_WEBHOOK_URL=https://webhook.site/YOUR-UNIQUE-ID
# TradersPost webhook URL for TradingView → Alpaca order execution (fires only with execute=True)
TRADERSPOST_WEBHOOK_URL=https://webhooks.traderspost.io/trading/webhook/YOUR-WEBHOOK-ID/YOUR-TOKEN
