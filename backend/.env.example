# Elite Trading System — Backend .env.example
# Copy to .env and fill in your values. All API keys default to empty.
# Features auto-disable when keys are missing.

# ── App Settings ─────────────────────────────────────────
APP_NAME=Elite Trading System API
APP_VERSION=3.1.0
DEBUG=False
LOG_LEVEL=INFO
ENVIRONMENT=development
PORT=8000
HOST=0.0.0.0
TRADING_MODE=paper
SCAN_INTERVAL_MINUTES=5

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8501

# ── WebSocket ────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=50

# ── Alpaca Markets (Paper Trading) ───────────────────────
# https://alpaca.markets/
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
# iex = free delayed feed, sip = paid real-time feed
ALPACA_FEED=iex
# Duplicate env names used by alpaca-py SDK
APCA_API_KEY_ID=your-alpaca-api-key
APCA_API_SECRET_KEY=your-alpaca-secret-key
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# ── Finviz Elite ─────────────────────────────────────────
# https://elite.finviz.com/
FINVIZ_API_KEY=your-finviz-api-key
FINVIZ_BASE_URL=https://elite.finviz.com
FINVIZ_SCREENER_FILTERS=sh_avgvol_o500,sh_price_u500
FINVIZ_SCREENER_FILTER_TYPE=4
FINVIZ_SCREENER_VERSION=111
FINVIZ_QUOTE_TIMEFRAME=d

# ── FRED (Federal Reserve Economic Data) ─────────────────
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# ── SEC EDGAR ────────────────────────────────────────────
SEC_EDGAR_USER_AGENT=YourName your@email.com

# ── News API ─────────────────────────────────────────────
# https://newsapi.org/
NEWS_API_KEY=your-news-api-key

# ── StockGeist (Social Sentiment) ────────────────────────
# https://stockgeist.ai/
STOCKGEIST_API_KEY=your-stockgeist-api-key
STOCKGEIST_BASE_URL=https://api.stockgeist.ai

# ── Unusual Whales (Options Flow) ────────────────────────
# https://unusualwhales.com/
UNUSUAL_WHALES_API_KEY=your-unusual-whales-api-key
# OpenClaw uses this alternate name:
UNUSUALWHALES_API_KEY=your-unusual-whales-api-key
UNUSUAL_WHALES_BASE_URL=https://api.unusualwhales.com/api

# ── YouTube Knowledge Agent ──────────────────────────────
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_SEARCH_QUERY=stock trading signals analysis

# ── X / Twitter ──────────────────────────────────────────
# https://developer.x.com/
X_API_KEY=your-x-api-key
X_API_KEY_SECRET=your-x-api-key-secret
X_OAUTH2_CLIENT_ID=your-x-oauth2-client-id
X_OAUTH2_CLIENT_SECRET=your-x-oauth2-client-secret
# OpenClaw read-only API v2 bearer token:
X_BEARER_TOKEN=

# ── Discord ──────────────────────────────────────────────
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_IDS=
DISCORD_UW_CHANNEL_ID=
DISCORD_FOM_CHANNEL_ID=
DISCORD_EXPECTED_MOVES_CHANNEL_ID=
DISCORD_MAVERICK_CHANNEL_ID=

# ── Resend (Email Alerts) ───────────────────────────────
# https://resend.com/
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=alerts@yourdomain.com
RESEND_ALERT_TO_EMAIL=you@yourdomain.com

# ── Telegram (Alerts) ───────────────────────────────────
# https://core.telegram.org/bots
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Multi-LLM Intelligence Layer ────────────────────────
# https://docs.perplexity.ai/
PERPLEXITY_API_KEY=your-perplexity-api-key
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_ENABLED=true
# https://docs.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Local LLM via Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
LOCAL_LLM_MODEL=qwen3:14b
LLM_ENABLED=true
LLM_PREFER_LOCAL=true
LLM_ROUTER_ENABLED=true

# ── Brain Service (PC2 gRPC) ────────────────────────────
BRAIN_ENABLED=false
BRAIN_HOST=localhost
BRAIN_PORT=50051

# ── Council (11-Agent Debate) ───────────────────────────
# 8 core agents + 3 data-source perception agents (social, news, youtube)
COUNCIL_ENABLED=true

# ── OpenClaw (Multi-Agent Swarm) ────────────────────────
OPENCLAW_ENABLED=false
OPENCLAW_BRIDGE_TOKEN=your-bridge-token
GIST_TOKEN=your-github-pat-with-gist-scope
BRIDGE_GIST_ID=your-github-gist-id

# ── Kelly Criterion & Position Sizing ────────────────────
KELLY_MAX_ALLOCATION=0.10
KELLY_DEFAULT_WIN_RATE=0.55
KELLY_DEFAULT_AVG_WIN=0.035
KELLY_DEFAULT_AVG_LOSS=0.015
KELLY_USE_HALF=True

# ── Risk Management ─────────────────────────────────────
MAX_PORTFOLIO_HEAT=0.06
MAX_SINGLE_POSITION=0.02
MAX_SECTOR_CONCENTRATION=0.30
MAX_DAILY_LOSS_PCT=2.0
DEFAULT_RISK_PCT=1.5
MIN_RISK_SCORE=3.0
VOLATILITY_BASELINE=0.15
CIRCUIT_BREAKER_THRESHOLD=-0.03
ATR_STOP_MULTIPLIER=2.0
MAX_DAILY_DRAWDOWN_PCT=5.0
AUTO_PAUSE_TRADING=True
TRAILING_STOP_PCT=0.03
MAX_POSITION_PCT=0.10

# ── Signal Thresholds ───────────────────────────────────
SIGNAL_BUY_THRESHOLD=0.60
SIGNAL_STRONG_BUY_THRESHOLD=0.75
SIGNAL_MIN_EDGE=0.05
SIGNAL_MIN_VOLUME_SCORE=0.5

# ── Execution Realism ───────────────────────────────────
SLIPPAGE_BPS=5.0
PARTIAL_FILL_ENABLED=true
AUTO_EXECUTE_TRADES=false
AUTO_EXECUTE_ENABLED=false
MAX_DAILY_TRADES=10

# ── Scheduler ───────────────────────────────────────────
SCHEDULER_ENABLED=false

# ── Database ────────────────────────────────────────────
DATABASE_URL=duckdb:///data/elite_trading.duckdb

# ── ML Engine ───────────────────────────────────────────
ML_MODEL_DIR=data/models
ML_RETRAIN_INTERVAL_HOURS=168
ML_ENSEMBLE_ENABLED=true

# ── Streaming ───────────────────────────────────────────
STREAMING_ENABLED=true
STREAMING_BAR_TIMEFRAME=1Min
SCORE_TRIGGER_THRESHOLD=75

# ── API Authentication ──────────────────────────────────
# Required for live trading. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_AUTH_TOKEN=

# ── Encryption Key ──────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for persistent credential encryption across restarts
FERNET_KEY=
