# Application Settings
APP_NAME=Elite Trading System API
DEBUG=False
API_V1_PREFIX=/api/v1
PORT=8000
HOST=0.0.0.0

# Finviz API Configuration
# Get your API key from: https://elite.finviz.com/
FINVIZ_API_KEY=your_finviz_api_key_here
FINVIZ_BASE_URL=https://elite.finviz.com
FINVIZ_SCREENER_FILTERS=cap_midover,sh_avgvol_o500,sh_price_o10
FINVIZ_SCREENER_VERSION=111
FINVIZ_SCREENER_FILTER_TYPE=4
FINVIZ_QUOTE_TIMEFRAME=d

# Alpaca Markets API Configuration
# Get your API keys from: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# Paper (default): https://paper-api.alpaca.markets  |  Live: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
# iex = free delayed feed, sip = paid real-time feed
ALPACA_FEED=iex
# paper = fake money (default). Set to "live" only when ready for real execution.
TRADING_MODE=paper

# OpenClaw Bridge — connects to OpenClaw scanner via GitHub Gist
# Get the Gist ID from your OpenClaw repo's api_data_bridge.py output
OPENCLAW_GIST_ID=your_openclaw_gist_id_here
# Optional: GitHub personal access token with gist scope (only needed for private gists)
OPENCLAW_GIST_TOKEN=your_github_token_here

# Kelly Criterion & Position Sizing
KELLY_MAX_ALLOCATION=0.10
KELLY_DEFAULT_WIN_RATE=0.55
KELLY_DEFAULT_AVG_WIN=0.035
KELLY_DEFAULT_AVG_LOSS=0.015
KELLY_USE_HALF=True
MAX_PORTFOLIO_HEAT=0.25
MAX_SECTOR_CONCENTRATION=0.25
VOLATILITY_BASELINE=0.02

# Signal Thresholds
SIGNAL_BUY_THRESHOLD=0.60
SIGNAL_STRONG_BUY_THRESHOLD=0.75
SIGNAL_MIN_EDGE=0.05
SIGNAL_MIN_VOLUME_SCORE=0.5

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=50

# Risk Management & Drawdown Protection
ATR_STOP_MULTIPLIER=2.0
MAX_DAILY_DRAWDOWN_PCT=5.0
MAX_DAILY_LOSS_PCT=2.0
AUTO_PAUSE_TRADING=True
VAR_LIMIT_PCT=1.5
RISK_FREE_RATE=0.05
MIN_RISK_SCORE=40
TRAILING_STOP_PCT=0.03
MAX_POSITION_PCT=0.10

# ── Brain Service (PC2) ─────────────────────────────────
# Set BRAIN_ENABLED=true and BRAIN_HOST to PC2's IP to use LLM inference
BRAIN_ENABLED=false
BRAIN_HOST=localhost
BRAIN_PORT=50051
OLLAMA_MODEL=llama3.2

# ── Council (11-Agent Debate) ───────────────────────────
# 8 core agents + 3 data-source perception agents (social, news, youtube)
COUNCIL_ENABLED=true

# ── Execution Realism ───────────────────────────────────
SLIPPAGE_BPS=5.0
PARTIAL_FILL_ENABLED=true
# FILL_SEED=42  # Set for deterministic paper fills

# ── Flywheel Scheduler ─────────────────────────────────
# Set to true for automatic daily/weekly jobs (outcome resolution, retraining)
SCHEDULER_ENABLED=false

# ── Risk Guardrails (Anti-Reward-Hacking) ──────────────
MAX_PORTFOLIO_HEAT=0.06
MAX_SINGLE_POSITION=0.02

# ── Safety ──────────────────────────────────────────────
AUTO_EXECUTE_TRADES=false

# ── Unusual Whales (Options Flow) ─────────────────────
# Get your API key from: https://unusualwhales.com/
UNUSUAL_WHALES_API_KEY=your_unusual_whales_api_key_here
UNUSUALWHALES_API_KEY=your_unusual_whales_api_key_here
UNUSUAL_WHALES_BASE_URL=https://api.unusualwhales.com/api

# ── Multi-LLM Intelligence Layer ─────────────────────
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar-pro
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
LLM_ROUTER_ENABLED=true

# ── API Authentication ────────────────────────────────
# Required for live trading. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_AUTH_TOKEN=

# ── FRED (Federal Reserve Economic Data) ──────────────
FRED_API_KEY=your_fred_api_key_here

# ── SEC EDGAR ─────────────────────────────────────────
SEC_EDGAR_USER_AGENT=YourName your@email.com

# ── Social Sentiment Sources ─────────────────────────
# StockGeist: https://stockgeist.ai/
STOCKGEIST_API_KEY=your_stockgeist_api_key_here
STOCKGEIST_BASE_URL=https://api.stockgeist.ai

# News API: https://newsapi.org/
NEWS_API_KEY=your_news_api_key_here

# Discord (bot token + channel IDs): https://discord.com/developers
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2

# X/Twitter (OAuth2 app-only): https://developer.x.com/
X_OAUTH2_CLIENT_ID=your_x_client_id_here
X_OAUTH2_CLIENT_SECRET=your_x_client_secret_here

# YouTube Data API: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_SEARCH_QUERY=stock trading signals analysis

# Resend (email alerts): https://resend.com/
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=alerts@elite-trading.dev
RESEND_ALERT_TO_EMAIL=your_email@example.com

# Telegram (alerts): https://core.telegram.org/bots
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Encryption Key ──────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for persistent credential encryption across restarts
FERNET_KEY=
