{
  "name": "embodier-trader",
  "version": "4.1.0",
  "description": "Embodier Trading System — AI-Powered Trading Platform",
  "main": "main.js",
  "author": "Embodier.ai",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "ai.embodier.trader",
    "productName": "Embodier Trader",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "backend-manager.js",
      "device-config.js",
      "peer-monitor.js",
      "service-orchestrator.js",
      "ollama-fallback.js",
      "auto-updater.js",
      "mobile-server.js",
      "tray.js",
      "pages/**",
      "icons/**",
      "assets/**",
      "node_modules/**"
    ],
    "extraResources": [
      { "from": "../backend/dist/embodier-backend", "to": "backend/embodier-backend" },
      { "from": "../frontend-v2/dist", "to": "frontend" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-log": "^5.3.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1"
  }
}
