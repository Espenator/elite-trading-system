# =========== Embodier Trader — PC2 (ProfitTrader) .env ===========
# Copy to backend/.env on PC2. Never commit secrets.
# PC2 = SECONDARY: brain_service gRPC, Ollama inference, GPU training

# ── Machine Identity ─────────────────────────────────────
PC_ROLE=secondary
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ── Brain Service (gRPC Server — this machine) ──────────
# Binds to 0.0.0.0 so PC1 can reach us over LAN
BRAIN_ENABLED=true
BRAIN_HOST=0.0.0.0
BRAIN_PORT=50051
BRAIN_SERVICE_URL=0.0.0.0:50051
BRAIN_SERVICE_TIMEOUT=1.5
BRAIN_MAX_WORKERS=8

# ── Ollama (Local GPU Inference) ────────────────────────
# RTX 4080: 16GB VRAM — gemma3:12b primary, qwen3:8b secondary
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b
LOCAL_LLM_MODEL=gemma3:12b
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_NUM_GPU=1
OLLAMA_GPU_LAYERS=50
OLLAMA_NUM_THREAD=4
OLLAMA_NUM_PARALLEL=4

# ── GPU / CUDA ──────────────────────────────────────────
GPU_TELEMETRY_ENABLED=true
GPU_TELEMETRY_INTERVAL=3.0
GPU_VRAM_HEADROOM_MB=512
EMBEDDING_DEVICE=cuda

# VRAM Budget (16 GB total):
#   Ollama gemma3:12b   ~8.2 GB
#   Ollama qwen3:8b     ~5.5 GB (when swapped)
#   XGBoost CUDA        ~2.0 GB
#   CUDA runtime        ~1.0 GB
#   Safety headroom     ~1.5 GB

# ── LLM (PC2 handles heavy inference) ───────────────────
LLM_ENABLED=true
LLM_PREFER_LOCAL=true
LLM_ROUTER_ENABLED=true
MODEL_PIN_PC2=gemma3:12b,qwen3:8b
MODEL_PIN_TASK_AFFINITY=trade_thesis:pc2,strategy_critic:pc2,deep_postmortem:pc2,strategy_evolution:pc2,overnight_analysis:pc2

# ── Redis (Connect to PC1's Redis) ──────────────────────
REDIS_URL=redis://192.168.1.105:6379
REDIS_REQUIRED=false

# ── Cluster ─────────────────────────────────────────────
CLUSTER_PC2_HOST=
PC1_API_URL=http://192.168.1.105:8001

# ── Alpaca (Key 2 — Discovery Scanning) ─────────────────
ALPACA_API_KEY=<your-alpaca-key-2>
ALPACA_SECRET_KEY=<your-alpaca-secret-2>
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_DATA_URL=https://data.alpaca.markets

# ── DuckDB (PC2 local analytics) ────────────────────────
DUCKDB_PATH=./data/trading.duckdb

# ── ML Engine ───────────────────────────────────────────
ML_MODEL_DIR=data/models
ML_ENSEMBLE_ENABLED=true

# ── Auth (same token as PC1 for cross-PC API calls) ─────
API_AUTH_TOKEN=<your-api-auth-token>
